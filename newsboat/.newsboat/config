browser "xdg-open %u"
download-full-page yes

html-renderer "w3m -dump -T text/html -cols 100"
# m = play the current link in mpv (works for YouTube etc.)
macro m set browser "mpv %u"; open-in-browser; set browser "xdg-open %u"

# t = open the current link in a terminal browser (links2)
macro t set browser "w3m -o display_image=0 -o inline_img=0 -no-graph %u"; open-in-browser; set browser "xdg-open %u"

# f = force Firefox (even if xdg-open points elsewhere)
macro f set browser "firefox %u"; open-in-browser; set browser "xdg-open %u"
# --- Vim-ish navigation in feed list and article list ---
bind-key j down feedlist
bind-key k up feedlist

bind-key j down articlelist
bind-key k up articlelist

# In article view, "down/up" scrolls
bind-key j down article
bind-key k up article

# In feed list: l opens feed, h quits
bind-key l open feedlist
bind-key h quit feedlist

# In article list: l opens article, h returns to feed list
bind-key l open articlelist
bind-key h quit articlelist

# In article view: h closes the view (back to article list)
bind-key h quit article
