# ---- color-aware aliases ----

alias ls='ls --color=auto -hF'

alias dir='eza -l --no-permissions --no-user \
  --time-style=relative --sort=modified -r --only-dirs'

alias vdir='eza -l --header \
  --time-style=long-iso --only-dirs --sort=modified -r'

alias grep='grep --color=auto'
alias diff='diff --color=auto'

alias ..='cd ..'
alias ...='cd ../..'
alias ll='ls -lh'
alias la='ls -a --group-directories-first'
alias lt='ls --sort=time -l -r'
alias shred='shred -vzun'
alias pw='pwgen -syn -1'
alias tn='clear; task next'
alias exall='exiftool -all= -overwrite_original'
alias uu='sudo nala update && sudo nala upgrade'
alias fast='fastfetch'
alias bye='sudo shutdown now'
alias argos-on='source /home/lukasz/venv-argos/bin/activate'
alias argos-off='deactivate'
alias argos='/home/lukasz/venv-argos/bin/argos-translate'
alias bat='batcat'
alias fd='fdfind'
alias cdwm='vim ~/git/dwm/config.h'
alias mdwm='cd ~/git/dwm; sudo make clean install; cd -'
alias cst='vim ~/git/st/config.def.h'
alias mst='cd ~/git/st; cp -f config.def.h config.h; make clean; sudo make install; hash -r; cd -'
alias work-on='sudo cryptsetup open ~/secure/containers/work-vault.img vault && sudo mount /dev/mapper/vault ~/docs/vault'
alias work-off='sudo umount ~/docs/vault && sudo cryptsetup close vault'
alias ncdu='ncdu --color dark'
alias mp='ncmpcpp'
alias v='vim'
alias sc='sc-im'
alias elf='eza --only-files --icons -l --sort=modified --time-style=relative -r'
alias clip='xclip -selection clipboard'
alias bm='bashmount'
alias wttr='curl wttr.in/50.017077345305175,21.752692000917033'
alias vmls='kvm-lab-status'
alias wg-down='sudo wg-quick down wg-sanctum' # disable only the WG tunnel and keep Proton & internet)
alias wg-up='sudo wg-quick up wg-sanctum' # bring WG back up manually
alias vzsh='vim ~/.zshrc'
alias szsh='source ~/.zshrc'
alias val='vim ~/.zsh_aliases'
alias neo='bridge-sync; notmuch new; mail-i2-fetch; neomutt'
alias nms='notmuch search --limit=25'
alias nmr='notmuch show --format=text'
alias nmn='notmuch new'
alias qr-scan='flameshot gui -r | zbarimg --quiet --raw -'
alias zat='zathura'
alias radicale-sync='calcurse-caldav && vdirsyncer sync'
alias just -g='just --global-justfile'
